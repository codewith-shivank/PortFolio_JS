# ═══════════════════════════════════════════════════════════════
#  Shivank Maurya Portfolio — Server Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit your actual .env file to Git
# ═══════════════════════════════════════════════════════════════

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local:   mongodb://127.0.0.1:27017/portfolio
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# JWT Secret — MUST be a long, random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_IN_PRODUCTION

# Secret for first-time admin registration (set this before registering admin)
ADMIN_REGISTRATION_SECRET=CHANGE_ME_PICK_A_UNIQUE_SECRET

# CORS — Frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Cloudinary (optional — for image uploads in admin dashboard)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
